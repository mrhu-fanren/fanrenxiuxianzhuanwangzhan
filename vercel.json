{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/cron/bilibili.js", "use": "@vercel/node" },
    { "src": "api/cron/spam.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/bilibili", "schedule": "0 0 * * *" },
    { "path": "/api/cron/spam", "schedule": "0 19 * * *" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
